DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

FIREBASE_API_KEY=<firebase-web-api-key>
FIREBASE_PROJECT_ID=<firebase-project-id>
FIREBASE_STORAGE_BUCKET=<firebase-storage-bucket>
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# SMTP settings for ticket notifications
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<smtp-user>
SMTP_PASS=<smtp-pass>
TICKET_FROM_EMAIL=ticketera@capassotech.local
TICKET_SUPPORT_EMAILS=soporte@capassotech.local
TICKET_PUBLIC_URL=http://localhost:5173/seguimiento

GOOGLE_SHEETS_TIME_ENTRIES_WEBHOOK_URL=<google-apps-script-exec-url>
